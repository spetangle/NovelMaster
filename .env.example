# NovelMaster 环境变量配置
# 复制此文件为 .env 并填写实际值

# =============================================================================
# LLM 配置 (多提供商支持)
# =============================================================================
# 格式: JSON，包含 providers 数组和 active_provider_id
#
# 字段说明:
#   - id: 提供商唯一标识（可自定义）
#   - name: 提供商名称（显示用）
#   - api_key: API 密钥
#   - base_url: API 地址
#   - model: 模型名称
#   - max_tokens: 最大 token 数
#   - temperature: 温度参数 (0-1)
#   - timeout: 超时时间（秒）
#   - retry_times: 重试次数
#   - retry_delay: 重试延迟（秒）
#   - enabled: 是否启用
#   - is_default: 是否默认提供商

LLM_CONFIG_JSON={"providers": [
  {
    "id": "provider_1",
    "name": "硅基流动",
    "api_key": "your-api-key-here",
    "base_url": "https://api.siliconflow.cn/v1",
    "model": "Qwen/Qwen2.5-7B-Instruct",
    "max_tokens": 8192,
    "temperature": 0.7,
    "timeout": 120,
    "retry_times": 3,
    "retry_delay": 2.0,
    "enabled": true,
    "is_default": true
  }
], "active_provider_id": "provider_1"}

# =============================================================================
# 常用提供商配置示例
# =============================================================================

# 硅基流动 (SiliconFlow)
# base_url: https://api.siliconflow.cn/v1
# 推荐模型: Qwen/Qwen2.5-7B-Instruct, deepseek-ai/DeepSeek-V3, Qwen/Qwen2.5-14B-Instruct

# DeepSeek
# base_url: https://api.deepseek.com/v1
# 模型: deepseek-chat, deepseek-coder

# OpenAI
# base_url: https://api.openai.com/v1
# 模型: gpt-4o-mini, gpt-4o, gpt-3.5-turbo

# 智谱 AI (Zhipu)
# base_url: https://open.bigmodel.cn/api/paas/v4
# 模型: glm-4-flash, glm-4, glm-4-plus

# MiniMax
# base_url: https://api.minimaxi.com/v1
# 模型: MiniMax-M2.7, MiniMax-Text-01

# =============================================================================
# 兼容旧格式 (单个提供商)
# =============================================================================
# 以下字段已废弃，仅作兼容保留
# 推荐使用上方 LLM_CONFIG_JSON 格式

# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=your-api-key-here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MAX_TOKENS=8192
# LLM_TEMPERATURE=0.7
# LLM_TIMEOUT=120
# LLM_RETRY_TIMES=3
# LLM_RETRY_DELAY=2.0